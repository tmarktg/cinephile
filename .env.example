# Anthropic API key — required for LLM rank + explain step
# Get yours at: https://console.anthropic.com
# Without this key the system still serves results in degraded mode (vector ranking only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TMDB API key — required for the data ingest step only
# Get yours at: https://www.themoviedb.org/settings/api (free account)
TMDB_API_KEY=your_tmdb_api_key_here

# Qdrant URL — the default below matches the docker-compose service name
# For Qdrant Cloud: https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_URL=http://qdrant:6333

# Qdrant API key — leave empty for local Qdrant; required for Qdrant Cloud
QDRANT_API_KEY=

# CORS allowed origins — comma-separated list of origins that may call the API
# Default "*" is fine for local dev; set to your deployed URL in production
# Example: https://cinephile.fly.dev
ALLOWED_ORIGINS=*

# Rate limit per IP per minute on /recommend and /recommend/stream (default: 10)
RATE_LIMIT_PER_MINUTE=10
